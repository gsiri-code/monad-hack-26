# Telegram user account API (from https://my.telegram.org)
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
# After first login, paste the session string here to avoid re-auth
TELEGRAM_SESSION=

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (server-side secret; do not expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public Supabase vars (same URL, anon/public key from dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Token bridge encryption key (64 hex chars = 32 bytes AES-256 key)
# Generate with: openssl rand -hex 32
BRIDGE_ENCRYPTION_KEY=your-64-hex-char-key

# Public app URL for server-side internal fetch calls
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenClaw skill base URL (same as NEXT_PUBLIC_APP_URL for local dev)
MONAD_API_URL=http://localhost:3000

# Smart contract + on-chain config
# Private key of the deployed contract owner (used for unshieldAndPay)
SERVER_PRIVATE_KEY=your-server-private-key-hex

# Monad testnet RPC (defaults to https://testnet-rpc.monad.xyz if not set)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployed Web3VenmoShield contract address
SHIELD_CONTRACT_ADDRESS=0xf9a83f9322113C6fe84Ed6EFE8affB0b57fB39ac

# ERC-20 token address to use for shielding/unshielding
SHIELD_TOKEN_ADDRESS=your-erc20-token-address

# Unlink SDK server wallet mnemonic (auto-generated on first run if not set)
UNLINK_MNEMONIC=
